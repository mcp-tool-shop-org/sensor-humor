{
  "name": "@mcptoolshop/sensor-humor",
  "version": "1.1.1",
  "description": "MCP comedy sidekick — gives LLMs a sense of humor via Ollama-powered comedic personality",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "sensor-humor": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "humor",
    "comedy",
    "ollama",
    "llm",
    "personality"
  ],
  "author": "mcp-tool-shop",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcp-tool-shop-org/sensor-humor.git"
  },
  "bugs": {
    "url": "https://github.com/mcp-tool-shop-org/sensor-humor/issues"
  },
  "homepage": "https://mcp-tool-shop-org.github.io/sensor-humor/",
  "files": [
    "dist",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ollama": "^0.5.14",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
