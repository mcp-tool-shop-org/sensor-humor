# Ollama model to use for comedy generation
SENSOR_HUMOR_MODEL=qwen2.5:7b

# Ollama host (default: http://127.0.0.1:11434)
OLLAMA_HOST=http://127.0.0.1:11434

# Ollama call timeout in ms (default: 30000; invalid/non-numeric values fall back to the default)
SENSOR_HUMOR_TIMEOUT_MS=30000

# Generation temperature, clamped 0.0-2.0 (default: 0.55; invalid values fall back to the default)
SENSOR_HUMOR_TEMPERATURE=0.55

# Enable verbose logging of prompts, raw responses, and generation metadata
SENSOR_HUMOR_DEBUG=false

# Prompt version (loads moods/{mood}.v{version}.prompt.ts, fallback to v1)
SENSOR_HUMOR_PROMPT_VERSION=1
